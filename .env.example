# EOA private key (with or without 0x prefix).
# This address must be the whitelisted GoodDollar identity on both Fuse and XDC,
# and must hold native FUSE and native XDC to pay for gas.
PRIVATE_KEY=

# Optional RPC overrides — fall back to viem's default chain RPCs if unset.
FUSE_RPC_URL=
XDC_RPC_URL=

# Optional minimum native gas balance (in ether units) required before claiming.
# Defaults to 0.01 if unset.
MIN_GAS_BALANCE=
